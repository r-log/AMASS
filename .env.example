# ===========================================================================
# Electrician Log MVP — Environment Variables
#
# Copy this file to .env and fill in production values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# ===========================================================================

# ---------------------------------------------------------------------------
# Core / Flask
# ---------------------------------------------------------------------------

# [REQUIRED] Random secret for JWT signing and session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Environment: development | production | testing
FLASK_ENV=production

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite database path (production default: /app/data/database.db inside Docker)
DATABASE_PATH=/app/data/database.db

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Comma-separated allowed CORS origins.
# Set to your actual domain in production.
CORS_ORIGINS=https://your-domain.com

# JWT token lifetime in hours (default: 8 for production, 24 for dev)
JWT_EXPIRATION_HOURS=8

# URL scheme — set to "https" when behind a TLS-terminating reverse proxy.
# Enables HSTS header.
PREFERRED_URL_SCHEME=https

# Max upload size in bytes (default: 16 MB)
MAX_CONTENT_LENGTH=16777216

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=WARNING

# Log format (Python logging format string)
# LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s %(funcName)s:%(lineno)d — %(message)s

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------

# Master switch (true / false)
RATE_LIMIT_ENABLED=true

# Backend: "memory" (single process) or "redis" (distributed)
RATE_LIMIT_BACKEND=redis

# Required when RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://redis:6379/0

# Default limit for endpoints without a specific rule: "requests/seconds"
RATE_LIMIT_DEFAULT=100/60

# ---------------------------------------------------------------------------
# File Storage (Docker volume mount points)
# ---------------------------------------------------------------------------

# Directory for uploaded floor plan PDFs / images
FLOOR_PLANS_DIR=/app/floor-plans

# Directory for project backup ZIP archives
PROJECT_BACKUPS_DIR=/app/project-backups

# Directory for generated map tiles
TILES_DIRECTORY=/app/backend/tiles

# ---------------------------------------------------------------------------
# Tile Generation
# ---------------------------------------------------------------------------

# Tile size in pixels
TILE_SIZE=512

# Tile overlap in pixels
TILE_OVERLAP=1

# DPI for PDF-to-image conversion
TILE_DPI=300

# Output format: webp | png | jpeg
TILE_FORMAT=webp

# Quality for WebP/JPEG (0-100)
TILE_QUALITY=85

# Max zoom level (0 = unlimited / full resolution)
TILE_MAX_LEVEL=0

# ---------------------------------------------------------------------------
# Pagination
# ---------------------------------------------------------------------------

DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# ---------------------------------------------------------------------------
# Deployment (GitHub Actions — set as repo secrets, not here)
# ---------------------------------------------------------------------------

# DEPLOY_HOST=your-server.example.com
# DEPLOY_USER=deploy
# DEPLOY_SSH_KEY=<contents of ~/.ssh/id_ed25519>
